rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ['customer', 'admin'])
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - id: string (required)
    //   - customerUid: string (required)
    //   - customerName: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required, enum: ['pending', 'preparing', 'ready', 'delivered', 'cancelled'])
    //   - createdAt: string (required)
    //   - updatedAt: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "vtu26208@veltech.edu.in" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'admin'];
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerUid', 'customerName', 'items', 'total', 'status', 'createdAt']) &&
             data.customerUid is string &&
             data.customerName is string && data.customerName.size() < 100 &&
             data.items is list && data.items.size() < 50 &&
             data.total is number &&
             data.status in ['pending', 'preparing', 'ready', 'delivered', 'cancelled'] &&
             data.createdAt is string;
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'customer';
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.customerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.customerUid == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin() && isValidMenuItem(request.resource.data);
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
